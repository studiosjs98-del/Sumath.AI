# ──────────────────────────────────────────────────────────────────────────
# Sumath backend environment variables
# Copy to .env and fill in real values. Never commit the real .env file.
# ──────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────

# OpenAI API key — drives all AI tutoring, chat, photo solve, and practice
# generation endpoints. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service-role key — server-side only, full DB access. Get from
# Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Anthropic API key — used by /api/analysis/generate-analysis with OpenAI
# fallback. Required for Claude-based weakness analysis.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# JWT signing secret — must be a long random string in production. Tokens
# signed with the fallback default will be invalid across deploys.
JWT_SECRET=change-me-to-a-long-random-string

# Express-session secret — same idea as JWT_SECRET, change in production.
SESSION_SECRET=change-me-to-a-long-random-string

# ── Optional ──────────────────────────────────────────────────────────────

# Server port (default: 3001)
PORT=3001

# Public URL of this backend, used by the Google OAuth callback URL.
SERVER_URL=http://localhost:3001

# Frontend origin — used for CORS and the post-OAuth redirect.
CLIENT_URL=http://localhost:5173

# Google OAuth credentials. If either is missing, the /auth/google routes
# return 503 and the rest of the server still boots.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
